# `/ask` is disabled until the local Chat DB MCP binary and a least-privilege
# ASK_DATABASE_URL role are provisioned. In the configured discussion chat
# the command is available to every participant; private chats use the allowlist.
ASK_ENABLED=false
ASK_ALLOW_CHAT_ADMINS=true
ASK_PRIVATE_USER_IDS=
ASK_LLM_PROVIDER=
ASK_LLM_MODEL=
ASK_LLM_TEMPERATURE=0.2
ASK_LLM_MAX_TOKENS=1800
ASK_MAX_STEPS=7
ASK_TIMEOUT_SEC=45
ASK_MAX_CONCURRENCY=1
ASK_DB_MCP_COMMAND=
ASK_DB_MCP_ARGS=
ASK_DB_MCP_ENV=ASK_DATABASE_URL
ASK_DB_MCP_TIMEOUT_SEC=8
PROFILE_REFRESH_CONCURRENCY=4

LLM_PROVIDER=ollama
LLM_MODEL=
LLM_SUPPORTS_IMAGES=true
LLM_TEMPERATURE=0.45
LLM_MAX_TOKENS=90
