# Use a unique random password for the role created by bootstrap-role.sql.
ASK_DATABASE_URL=postgresql://nedobot_mcp_ro:REDACTED@127.0.0.1:5432/tg_ai_bot
MCP_BIND=127.0.0.1:8787
MCP_PATH=/mcp/nedonews
MCP_MANIFEST=/opt/tg-ai-bot-teloxide/config/mcp_db_manifest.toml
# Empty permits server-to-server MCP clients. A present Origin must be listed here.
MCP_ALLOWED_ORIGINS=https://chatgpt.com,https://chat.openai.com
RUST_LOG=info
